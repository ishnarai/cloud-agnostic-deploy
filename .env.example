# Copy to .env for local manual deployment testing (never commit real .env).

# Which cloud to target for manual/local script runs.
CLOUD_PROVIDER=aws

# Only needed for GCP scripts (no default project ID exists).
GCP_PROJECT_ID=your-gcp-project-id

# Image tag to deploy (normally supplied automatically by the CI repo).
IMAGE_TAG=ghcr.io/your-org/cloud-agnostic-app:latest
